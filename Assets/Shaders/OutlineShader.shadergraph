        {
            "m_Id": "1958c4d3c7654231a4b88bea1edbeb32"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "OutlineOffset",
    "m_FunctionSource": "6f8f33d2e967c8b4fbcfe0dfe48c0f8c",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "void OutlineOffset_float(float3 vertexOS, float3 normalOS, float width, float maxWidth, out float3 result)\r\n{\r\n    float3 offset = normalOS * min(width, maxWidth);\r\n    result = vertexOS + offset;\r\n}"
}

